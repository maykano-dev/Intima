# Velora Health — Environment Variables

# Supabase (get these from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Moolre (Mobile Money Payment Gateway — get these from your Moolre dashboard)
MOOLRE_USER=your_moolre_user
MOOLRE_PUB_KEY=your_moolre_pub_key
MOOLRE_ACCOUNT_NUMBER=your_moolre_account
MOOLRE_SECRET=your_moolre_webhook_secret

# WhatsApp Business (for customer notifications)
NEXT_PUBLIC_WHATSAPP_NUMBER=233XXXXXXXXX
